{
  "name": "synthesis",
  "version": "0.1.0",
  "private": true,
  "description": "Synthesis - voice-enabled, retrieval-assisted interview-prep platform.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "validate:prep": "python scripts/validation/prepare_data.py",
    "validate:fit": "tsx scripts/validation/score_resumes.ts",
    "validate:report": "python scripts/validation/validate_matching.py",
    "validate:smoke": "python scripts/validation/prepare_data.py --smoke && tsx scripts/validation/score_resumes.ts --smoke && python scripts/validation/validate_matching.py --smoke"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@supabase/supabase-js": "^2.108.1",
    "mammoth": "^1.12.0",
    "next": "^14.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "unpdf": "^1.6.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@xenova/transformers": "^2.17.2",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.22.4",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18.17.0"
  }
}
