# Synthesis — environment template.
# Copy to .env.local and fill in. The app runs fully on MOCKS with NO real
# credentials (`npm run dev` / `npm test`). Only fill these in to use live services.
# Deploying to Vercel? See docs/deployment.md — mock-mode needs only SYNTHESIS_USE_MOCKS=true.

# --- Claude API (live plane) ---
ANTHROPIC_API_KEY=
# Model toggle: "default" -> claude-haiku-4-5 (locked default), "demo" -> claude-sonnet-4-6
SYNTHESIS_MODEL_MODE=default
# Optional: log per-call token usage (input/output tokens) to server logs. Off by default;
# never fires in mock mode. Useful for cost/verification in real mode.
SYNTHESIS_LOG_USAGE=false

# --- Embeddings (local sentence-transformers; NEVER a paid API) ---
# Live plane uses BGE-small via @xenova/transformers when enabled. Leave disabled
# to use the deterministic mock embedder. O*NET itself stays a local JSON dictionary.
EMBEDDINGS_ENABLED=false
EMBEDDINGS_MODEL=Xenova/bge-small-en-v1.5
EMBEDDINGS_MODEL_REVISION=ea104dacec62c0de699686887e3f920caeb4f3e3
BGE_INFERENCE_CONCURRENCY=2

# --- Offline validation only ---
# Used only by scripts/validation/llm_family_map.py to label posting families.
# Never used on the live request path.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Mock mode ---
# When the Claude credential above is absent, the app auto-falls back to mocks.
# Set to "false" only when the live Claude credential is present.
SYNTHESIS_USE_MOCKS=true

# --- Vapi voice integration (server-only; used by /api/vapi/* routes) ---
# Upstash Redis holds voice-session state (Vercel functions are ephemeral, so an
# in-memory Map won't work). These EXACT variable names are provided by the Vercel
# Upstash integration — do not rename, alias, or use the read-only token. Never
# expose them to client code.
UPSTASH_REDIS_REST_KV_REST_API_URL=
UPSTASH_REDIS_REST_KV_REST_API_TOKEN=
# Shared secret verified as `Authorization: Bearer <secret>` on the Vapi tool
# webhook (/api/vapi/behavioural). Set the same value in Vapi.
VAPI_WEBHOOK_SECRET=

# --- Vapi Web SDK (client-safe; used by components/VoiceInterview.tsx) ---
# Public browser key + the behavioural assistant id. Safe to expose to the client;
# these are NOT the webhook secret. When either is unset, the voice panel is hidden
# and the page is unchanged.
NEXT_PUBLIC_VAPI_WEB_KEY=
NEXT_PUBLIC_VAPI_BEHAVIOURAL_ASSISTANT_ID=
